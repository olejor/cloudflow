policy_module(cloudflow_source_dhcp, 1.0.0)

########################################
#
# Declarations
#

## <desc>
##	<p>
##	CloudFlow wire-observed DHCP source: an AF_PACKET capture daemon that
##	parses DHCPv4/DHCPv6 off udp/67-68 and udp/546-547, normalizes each into
##	a protobuf CloudFlowEvent, and pushes it to Redis Streams.
##	</p>
## </desc>

type cloudflow_source_dhcp_t;
type cloudflow_source_dhcp_exec_t;
init_daemon_domain(cloudflow_source_dhcp_t, cloudflow_source_dhcp_exec_t)

# Private config type so only this domain can read the DHCP source config
# under /etc/cloudflow (the systemd unit ships no secrets for this source).
type cloudflow_source_dhcp_conf_t;
files_config_file(cloudflow_source_dhcp_conf_t)

########################################
#
# Local policy
#

# Capabilities. CAP_NET_RAW opens the AF_PACKET/PACKET_RX_RING capture socket;
# CAP_SYS_NICE raises the rx-reader to best-effort SCHED_FIFO (its absence is
# logged and capture continues at normal priority -- see the systemd unit).
allow cloudflow_source_dhcp_t self:capability { net_raw sys_nice };
allow cloudflow_source_dhcp_t self:process { getsched setsched signal signull };

# The pipeline is three threads coordinating over SPSC ring buffers.
allow cloudflow_source_dhcp_t self:fifo_file rw_fifo_file_perms;

# The TPACKET_V3 capture ring is an AF_PACKET socket: create/bind it, set the
# ring options (PACKET_RX_RING / PACKET_VERSION), mmap it (map), and read the
# interface index via ioctl.
allow cloudflow_source_dhcp_t self:packet_socket
	{ create bind read write getopt setopt ioctl map };

# Redis transport. Endpoints are configured as host:port (e.g. redis01:6379),
# so the daemon resolves names and makes an outbound TCP connection to a
# redis_port_t; it never listens.
allow cloudflow_source_dhcp_t self:tcp_socket create_stream_socket_perms;
corenet_all_recvfrom_unlabeled(cloudflow_source_dhcp_t)
corenet_all_recvfrom_netlabel(cloudflow_source_dhcp_t)
corenet_tcp_sendrecv_generic_if(cloudflow_source_dhcp_t)
corenet_tcp_sendrecv_generic_node(cloudflow_source_dhcp_t)
corenet_tcp_connect_redis_port(cloudflow_source_dhcp_t)
corenet_tcp_sendrecv_redis_port(cloudflow_source_dhcp_t)
sysnet_dns_name_resolve(cloudflow_source_dhcp_t)

# Read its own YAML config (and nothing else) under /etc/cloudflow.
read_files_pattern(cloudflow_source_dhcp_t, cloudflow_source_dhcp_conf_t, cloudflow_source_dhcp_conf_t)
files_search_etc(cloudflow_source_dhcp_t)

# Structured JSON logs are written to the inherited stderr fd, which systemd
# wires to journald; the syslog path is allowed for completeness.
logging_send_syslog_msg(cloudflow_source_dhcp_t)

# Read-only bits every daemon touches.
files_read_etc_files(cloudflow_source_dhcp_t)
miscfiles_read_localization(cloudflow_source_dhcp_t)
