[Unit]
Description=CloudFlow Splunk metrics sink
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Must define SPLUNK_HEC_TOKEN (or whatever env var splunk.hec_token_env in
# the YAML config names) -- decision D6: the HEC token is env-only, never in
# YAML. File is not committed; deploy it out of band, e.g.:
#   SPLUNK_HEC_TOKEN=...
EnvironmentFile=-/etc/cloudflow/splunk-metrics.env
ExecStart=/usr/local/bin/cloudflow-sink-splunk-metrics -c /etc/cloudflow/splunk-metrics.yaml
# SIGTERM triggers a flush-once-then-exit; give the in-flight batch time.
KillSignal=SIGTERM
TimeoutStopSec=15
Restart=on-failure
RestartSec=5
User=cloudflow
Group=cloudflow
NoNewPrivileges=true

# --- Sandboxing (project review G4) ----------------------------------------
# HTTP(S) egress + Redis TCP only: no raw sockets, so drop ALL capabilities.
# Stricter than the capture sources, which must keep CAP_NET_RAW.
CapabilityBoundingSet=
# AF_INET/6: HTTP(S) to the HEC + Redis TCP. AF_UNIX: NSS / journald.
# No AF_PACKET -- this daemon never opens a raw socket.
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
PrivateTmp=yes
# Whole FS read-only; the daemon writes nothing to disk (logs -> journald),
# so no ReadWritePaths are needed. It still reads /etc/cloudflow config r/o.
ProtectSystem=strict
ProtectHome=yes
ProtectControlGroups=yes
ProtectKernelModules=yes
ProtectKernelTunables=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
RestrictNamespaces=yes
SystemCallArchitectures=native
SystemCallFilter=@system-service

[Install]
WantedBy=multi-user.target
