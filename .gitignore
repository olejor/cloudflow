# build artifacts
build/
dist/
target/
*.o
*.so
*.a
*.exe

# NOTE: generated protobuf bindings (libs/cloudflow-codec/gen/,
# sinks/cloudflow-sink-splunk/src/cloudflow_pb/) are intentionally NOT
# ignored -- per Decision D2 (docs/architecture.md) generated code is
# committed so builds and CI never need protoc. See WP-02
# (docs/building-and-testing.md) and scripts/generate-protobuf.sh.

# local config and secrets
*.env
*.local.yaml
.env

# packet captures - avoid committing sensitive captures by accident
*.pcap
*.pcapng

# ...except the WP-06/07 fixture corpus: these are synthetically generated
# (never captured) by tests/fixtures/dhcp/generate_fixtures.py from
# documentation address space only, and are committed on purpose so tests
# don't need protoc/scapy at test time -- see docs/dhcp-source.md
# ("Fixture corpus").
!/tests/fixtures/dhcp/*.pcap

# editor files
.vscode/
.idea/
*.swp
.DS_Store

# local agent/tooling scratch (e.g. worktree isolation directories)
.claude/

# Python bytecode caches
__pycache__/
*.pyc

# Python packaging artifacts
*.egg-info/
