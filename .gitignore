# build artifacts
build/
dist/
target/
*.o
*.so
*.a
*.exe

# NOTE: generated protobuf bindings (libs/cloudflow-codec/gen/,
# sinks/cloudflow-sink-splunk/src/cloudflow_pb/) are intentionally NOT
# ignored -- per Decision D2 (docs/design/00-overview.md) generated code is
# committed so builds and CI never need protoc. See WP-02
# (docs/design/01-foundations.md) and scripts/generate-protobuf.sh.

# local config and secrets
*.env
*.local.yaml
.env

# packet captures - avoid committing sensitive captures by accident
*.pcap
*.pcapng

# editor files
.vscode/
.idea/
*.swp
.DS_Store

# Python bytecode caches
__pycache__/
*.pyc
